<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=Noto+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  <link rel="stylesheet" href="/css/naayak.css" />
</head>
<body>
<div class="layout">
  <%- include('../partials/citizen-sidebar') %>
  <div class="main-content">
    <div class="topbar">
      <div class="topbar-left">
        <a href="/citizen/grievances" style="color:var(--gray-600);text-decoration:none;font-size:0.85rem;display:flex;align-items:center;gap:0.3rem;"><i class="fas fa-arrow-left"></i> My Grievances</a>
        <span style="color:var(--gray-300);margin:0 0.5rem;">|</span>
        <span class="page-title"><%= grievance.grievanceId %></span>
      </div>
    </div>
    <div class="content">

      <% if (success) { %>
        <div class="alert alert-success" style="margin-bottom:1.25rem;"><i class="fas fa-check-circle"></i> <%= success %></div>
      <% } %>

      <div style="display:grid;grid-template-columns:1fr 300px;gap:1.5rem;align-items:start;">

        <div style="display:flex;flex-direction:column;gap:1.25rem;">

          <div class="card">
            <div class="card-body">
              <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:1rem;flex-wrap:wrap;margin-bottom:1.25rem;">
                <div>
                  <div style="font-family:'Rajdhani',sans-serif;font-size:0.78rem;font-weight:700;color:var(--gray-400);letter-spacing:0.08em;text-transform:uppercase;margin-bottom:0.25rem;"><%= grievance.grievanceId %></div>
                  <h2 style="font-size:1.35rem;margin-bottom:0.5rem;"><%= grievance.title %></h2>
                  <div style="display:flex;gap:0.5rem;flex-wrap:wrap;align-items:center;">
                    <% const sm={PENDING:'pending',ASSIGNED:'assigned',IN_PROGRESS:'progress',RESOLVED:'resolved',REJECTED:'rejected',ESCALATED:'escalated'}; %>
                    <span class="badge badge-<%= sm[grievance.status] %>" style="font-size:0.8rem;padding:0.3rem 0.8rem;"><%= grievance.status.replace('_',' ') %></span>
                    <span class="badge badge-<%= grievance.urgency.toLowerCase() %>"><span class="urgency-dot <%= grievance.urgency %>"></span><%= grievance.urgency %></span>
                    <span class="badge badge-primary"><%= grievance.category %></span>
                    <% if (grievance.aiConfidence > 0) { %><span class="ai-chip"><i class="fas fa-robot"></i> AI Classified</span><% } %>
                  </div>
                </div>
                <div style="text-align:right;">
                  <div style="font-size:0.7rem;color:var(--gray-400);">Filed on</div>
                  <div style="font-weight:700;font-size:0.9rem;"><%= new Date(grievance.createdAt).toLocaleDateString('en-IN',{day:'numeric',month:'long',year:'numeric'}) %></div>
                </div>
              </div>

              <div class="form-section-title">Your Complaint</div>
              <p style="font-size:0.9rem;line-height:1.75;color:var(--gray-800);background:var(--off-white);padding:1rem;border-radius:var(--radius-sm);border-left:3px solid var(--saffron);"><%= grievance.description %></p>

              <% if (grievance.resolutionNote) { %>
                <div style="margin-top:1rem;padding:1rem;background:var(--success-light);border-radius:var(--radius-sm);border-left:3px solid var(--success);">
                  <div style="font-size:0.72rem;font-weight:700;color:var(--success);text-transform:uppercase;letter-spacing:0.06em;margin-bottom:0.35rem;"><i class="fas fa-check-circle"></i> Resolution Note from Officer</div>
                  <p style="font-size:0.88rem;color:var(--text);"><%= grievance.resolutionNote %></p>
                </div>
              <% } %>

              <% if (grievance.attachments && grievance.attachments.length > 0) { %>
                <div style="margin-top:1rem;">
                  <div class="form-section-title">Your Attachments</div>
                  <div style="display:flex;gap:0.5rem;flex-wrap:wrap;">
                    <% grievance.attachments.forEach((att, i) => { %>
                      <a href="<%= att %>" target="_blank" class="btn btn-outline btn-sm"><i class="fas fa-paperclip"></i> Attachment <%= i+1 %></a>
                    <% }) %>
                  </div>
                </div>
              <% } %>
            </div>
          </div>

          <div class="card">
            <div class="card-header"><h3 class="card-title"><i class="fas fa-history" style="color:var(--saffron);margin-right:0.5rem;"></i>Grievance Timeline</h3></div>
            <div class="card-body">
              <% if (!grievance.timeline || grievance.timeline.length === 0) { %>
                <p style="color:var(--gray-400);font-size:0.85rem;">No updates yet. Check back soon.</p>
              <% } else { %>
                <div class="timeline">
                  <% const reversedTimeline = [...grievance.timeline].reverse(); %>
                  <% reversedTimeline.forEach(function(t) { %>
                    <div class="timeline-item">
                      <div class="timeline-time"><%= new Date(t.timestamp).toLocaleString('en-IN',{day:'numeric',month:'short',year:'numeric',hour:'2-digit',minute:'2-digit'}) %></div>
                      <div class="timeline-status"><%= t.status ? t.status.replace('_',' ') : '' %></div>
                      <div class="timeline-content"><%= t.message %></div>
                      <div style="font-size:0.7rem;color:var(--gray-400);margin-top:0.2rem;">
                        Updated by <%= t.updatedByRole === 'admin' ? 'Administrator' : t.updatedByRole === 'adhikari' ? 'Government Officer' : 'You' %>
                      </div>
                    </div>
                  <% }) %>
                </div>
              <% } %>
            </div>
          </div>
        </div>

        <div style="position:sticky;top:80px;display:flex;flex-direction:column;gap:1.1rem;">

          <div class="card">
            <div class="card-header" style="background:var(--navy);">
              <h3 class="card-title" style="color:var(--white);"><i class="fas fa-route" style="color:var(--saffron);margin-right:0.5rem;"></i>Progress</h3>
            </div>
            <div class="card-body">
              <% var steps = ['PENDING','ASSIGNED','IN_PROGRESS','RESOLVED']; %>
              <% var currentIdx = steps.indexOf(grievance.status); %>
              <div style="display:flex;flex-direction:column;">
                <% for (var si = 0; si < steps.length; si++) { %>
                  <% var step = steps[si]; %>
                  <div style="display:flex;align-items:flex-start;gap:0.75rem;padding-bottom:<%= si < steps.length-1 ? '1rem' : '0' %>;">
                    <div style="display:flex;flex-direction:column;align-items:center;flex-shrink:0;">
                      <div style="width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:0.75rem;font-weight:700;
                        background:<%= si < currentIdx ? 'var(--success)' : si === currentIdx ? 'var(--saffron)' : 'var(--gray-200)' %>;
                        color:<%= si <= currentIdx ? 'var(--white)' : 'var(--gray-400)' %>;">
                        <% if (si < currentIdx) { %><i class="fas fa-check"></i><% } else { %><%= si+1 %><% } %>
                      </div>
                      <% if (si < steps.length-1) { %>
                        <div style="width:2px;min-height:16px;flex:1;margin-top:2px;background:<%= si < currentIdx ? 'var(--success)' : 'var(--gray-200)' %>;"></div>
                      <% } %>
                    </div>
                    <div style="padding-top:4px;">
                      <div style="font-size:0.82rem;font-weight:<%= si === currentIdx ? '700' : '500' %>;
                        color:<%= si === currentIdx ? 'var(--saffron)' : si < currentIdx ? 'var(--success)' : 'var(--gray-400)' %>;">
                        <%= step.replace('_',' ') %>
                      </div>
                      <% if (si === currentIdx) { %><div style="font-size:0.7rem;color:var(--gray-600);">Current status</div><% } %>
                    </div>
                  </div>
                <% } %>
                <% if (grievance.status === 'REJECTED') { %>
                  <div style="margin-top:0.75rem;padding:0.65rem;background:var(--danger-light);border-radius:var(--radius-sm);font-size:0.78rem;color:var(--danger);">
                    <i class="fas fa-times-circle"></i> This grievance was rejected.
                  </div>
                <% } %>
              </div>
            </div>
          </div>

          <div class="card">
            <div class="card-header"><h3 class="card-title" style="font-size:0.9rem;"><i class="fas fa-building" style="color:var(--saffron);margin-right:0.5rem;"></i>Assignment Info</h3></div>
            <div class="card-body" style="display:flex;flex-direction:column;gap:0.75rem;">
              <div>
                <div style="font-size:0.7rem;font-weight:700;color:var(--gray-400);text-transform:uppercase;letter-spacing:0.06em;margin-bottom:0.2rem;">Department</div>
                <div style="font-size:0.88rem;font-weight:600;color:var(--navy);">
                  <%= grievance.department ? grievance.department.name : 'Not yet assigned' %>
                  <% if (grievance.department && grievance.department.code) { %>
                    <span style="font-size:0.7rem;color:var(--gray-400);font-weight:400;"> · <%= grievance.department.code %></span>
                  <% } %>
                </div>
              </div>
              <% if (grievance.assignedTo) { %>
              <div>
                <div style="font-size:0.7rem;font-weight:700;color:var(--gray-400);text-transform:uppercase;letter-spacing:0.06em;margin-bottom:0.2rem;">Handling Officer</div>
                <div style="font-size:0.88rem;font-weight:600;color:var(--navy);"><%= grievance.assignedTo.name %></div>
                <div style="font-size:0.75rem;color:var(--gray-600);"><%= grievance.assignedTo.designation %></div>
              </div>
              <% } %>
              <% if (grievance.resolvedAt) { %>
              <div>
                <div style="font-size:0.7rem;font-weight:700;color:var(--success);text-transform:uppercase;letter-spacing:0.06em;margin-bottom:0.2rem;">Resolved On</div>
                <div style="font-size:0.88rem;font-weight:600;color:var(--success);"><%= new Date(grievance.resolvedAt).toLocaleDateString('en-IN',{day:'numeric',month:'long',year:'numeric'}) %></div>
              </div>
              <% } %>
            </div>
          </div>

          <a href="/citizen/grievances" class="btn btn-outline btn-block"><i class="fas fa-arrow-left"></i> Back to My Grievances</a>
        </div>
      </div>
    </div>
  </div>
</div>
</body>
</html>
