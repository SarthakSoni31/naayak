<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=Noto+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  <link rel="stylesheet" href="/css/naayak.css" />
</head>
<body>
<div class="layout">
  <%- include('../partials/citizen-sidebar') %>
  <div class="main-content">
    <div class="topbar">
      <div class="topbar-left"><span class="page-title">My Dashboard</span></div>
    </div>
    <div class="content">

      <!-- Welcome Banner -->
      <div style="background:linear-gradient(135deg,var(--navy) 0%,var(--navy-light) 100%);border-radius:var(--radius);padding:1.5rem 2rem;margin-bottom:1.75rem;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;">
        <div>
          <h2 style="color:var(--white);margin-bottom:0.25rem;">Namaste, <%= user.name %> 🙏</h2>
          <p style="color:rgba(255,255,255,0.6);font-size:0.85rem;"><%= user.district %>, <%= user.state %> · Your Naayak Portal</p>
        </div>
        <a href="/citizen/grievance/new" class="btn btn-saffron">
          <i class="fas fa-plus-circle"></i> File New Grievance
        </a>
      </div>

      <div class="stats-grid">
        <div class="stat-card primary">
          <div class="stat-icon"><i class="fas fa-file-alt"></i></div>
          <div class="stat-info"><div class="stat-value"><%= stats.total %></div><div class="stat-label">Total Filed</div></div>
        </div>
        <div class="stat-card warning">
          <div class="stat-icon"><i class="fas fa-clock"></i></div>
          <div class="stat-info"><div class="stat-value"><%= stats.pending %></div><div class="stat-label">Pending</div></div>
        </div>
        <div class="stat-card info">
          <div class="stat-icon"><i class="fas fa-spinner"></i></div>
          <div class="stat-info"><div class="stat-value"><%= stats.inProgress %></div><div class="stat-label">In Progress</div></div>
        </div>
        <div class="stat-card success">
          <div class="stat-icon"><i class="fas fa-check-circle"></i></div>
          <div class="stat-info"><div class="stat-value"><%= stats.resolved %></div><div class="stat-label">Resolved</div></div>
        </div>
      </div>

      <!-- Quick Actions -->
      <div class="grid-2" style="margin-bottom:1.5rem;">
        <a href="/citizen/grievance/new" style="text-decoration:none;">
          <div class="card" style="border:2px dashed var(--saffron);background:var(--saffron-pale);transition:var(--transition);cursor:pointer;" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform=''">
            <div class="card-body" style="text-align:center;padding:2rem;">
              <div style="width:60px;height:60px;background:var(--saffron);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;font-size:1.5rem;">
                <i class="fas fa-plus" style="color:var(--white);"></i>
              </div>
              <h3 style="font-size:1.1rem;color:var(--navy);margin-bottom:0.25rem;">File a Grievance</h3>
              <p style="font-size:0.8rem;color:var(--gray-600);">AI-powered classification & auto-routing</p>
            </div>
          </div>
        </a>
        <a href="/citizen/track" style="text-decoration:none;">
          <div class="card" style="border:1.5px solid var(--gray-200);transition:var(--transition);cursor:pointer;" onmouseover="this.style.transform='translateY(-2px)';this.style.borderColor='var(--navy)'" onmouseout="this.style.transform='';this.style.borderColor='var(--gray-200)'">
            <div class="card-body" style="text-align:center;padding:2rem;">
              <div style="width:60px;height:60px;background:var(--navy);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;font-size:1.5rem;">
                <i class="fas fa-search" style="color:var(--white);"></i>
              </div>
              <h3 style="font-size:1.1rem;color:var(--navy);margin-bottom:0.25rem;">Track by ID</h3>
              <p style="font-size:0.8rem;color:var(--gray-600);">Check status using your Grievance ID</p>
            </div>
          </div>
        </a>
      </div>

      <!-- Recent Grievances -->
      <div class="card">
        <div class="card-header">
          <h3 class="card-title"><i class="fas fa-list" style="color:var(--saffron);margin-right:0.5rem;"></i>Recent Grievances</h3>
          <a href="/citizen/grievances" class="btn btn-outline btn-sm">View All</a>
        </div>
        <div class="table-wrapper">
          <table>
            <thead><tr><th>Grievance ID</th><th>Title</th><th>Category</th><th>Status</th><th>Department</th><th>Date</th><th>Track</th></tr></thead>
            <tbody>
              <% if (recent.length === 0) { %>
                <tr><td colspan="7">
                  <div class="empty-state">
                    <div class="empty-icon">📋</div>
                    <h3>No grievances filed yet</h3>
                    <p>File your first grievance to get started</p>
                    <a href="/citizen/grievance/new" class="btn btn-saffron" style="margin-top:1rem;"><i class="fas fa-plus"></i> File Now</a>
                  </div>
                </td></tr>
              <% } %>
              <% recent.forEach(g => { %>
                <tr>
                  <td><span style="font-family:'Rajdhani',sans-serif;font-weight:700;color:var(--navy);font-size:0.88rem;"><%= g.grievanceId %></span></td>
                  <td style="max-width:160px;font-size:0.83rem;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= g.title %></td>
                  <td><span class="badge badge-primary" style="font-size:0.68rem;"><%= g.category %></span></td>
                  <td>
                    <% const sm={PENDING:'pending',ASSIGNED:'assigned',IN_PROGRESS:'progress',RESOLVED:'resolved',REJECTED:'rejected'}; %>
                    <span class="badge badge-<%= sm[g.status] %>"><%= g.status.replace('_',' ') %></span>
                  </td>
                  <td style="font-size:0.78rem;color:var(--gray-600);"><%= g.department?.name || '— Unassigned' %></td>
                  <td style="font-size:0.75rem;color:var(--gray-600);"><%= new Date(g.createdAt).toLocaleDateString('en-IN') %></td>
                  <td><a href="/citizen/grievance/<%= g._id %>" class="btn btn-outline btn-sm btn-icon"><i class="fas fa-eye"></i></a></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>
</body>
</html>
