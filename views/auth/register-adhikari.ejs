<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=Noto+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  <link rel="stylesheet" href="/css/naayak.css" />
</head>
<body>
  <div class="auth-wrapper">

    <div class="auth-brand">
      <div class="emblem">🏅</div>
      <h1>ना<span>यक</span></h1>
      <p>Register as a Government Officer to manage and resolve citizen grievances efficiently.</p>
      <div style="margin-top:2rem;padding:1.25rem;background:rgba(255,255,255,0.06);border-radius:var(--radius);border:1px solid rgba(255,255,255,0.1);max-width:300px;">
        <p style="color:rgba(255,255,255,0.55);font-size:0.78rem;display:flex;align-items:flex-start;gap:0.5rem;">
          <i class="fas fa-clock" style="color:var(--saffron);margin-top:0.1rem;"></i>
          Registration requires Admin approval before you can login. This typically takes 1-2 business days.
        </p>
      </div>
      <div style="margin-top:1rem;padding:1rem 1.25rem;background:rgba(255,153,51,0.1);border-radius:var(--radius);border:1px solid rgba(255,153,51,0.2);max-width:300px;">
        <p style="color:rgba(255,255,255,0.8);font-size:0.82rem;font-weight:600;margin-bottom:0.5rem;">📋 Officer Workflow:</p>
        <div style="display:flex;flex-direction:column;gap:0.4rem;">
          <span style="color:rgba(255,255,255,0.6);font-size:0.78rem;">1. Submit registration</span>
          <span style="color:rgba(255,255,255,0.6);font-size:0.78rem;">2. Admin approves account</span>
          <span style="color:rgba(255,255,255,0.6);font-size:0.78rem;">3. Login & receive grievances</span>
          <span style="color:rgba(255,255,255,0.6);font-size:0.78rem;">4. Resolve & update status</span>
        </div>
      </div>
      <p class="auth-tagline">Serving citizens. Serving India.</p>
    </div>

    <div class="auth-card" style="overflow-y:auto;padding:2rem 2.5rem;">
      <div class="india-stripe" style="position:absolute;top:0;left:0;right:0;"></div>

      <div style="margin-bottom:1.5rem;">
        <a href="/login?role=adhikari" style="color:var(--gray-600);font-size:0.82rem;text-decoration:none;display:inline-flex;align-items:center;gap:0.3rem;margin-bottom:0.75rem;">
          <i class="fas fa-arrow-left"></i> Back to Login
        </a>
        <h2>Adhikari Registration</h2>
        <p class="subtitle">अधिकारी पंजीकरण — Government Officer Account</p>
      </div>

      <% if (error) { %>
        <div class="alert alert-danger"><i class="fas fa-exclamation-circle"></i> <%= error %></div>
      <% } %>
      <% if (success) { %>
        <div class="alert alert-success"><i class="fas fa-check-circle"></i> <%= success %></div>
      <% } %>

      <form action="/register/adhikari" method="POST">

        <div class="form-section-title">Personal Details</div>

        <div class="form-grid-2">
          <div class="form-group">
            <label class="form-label">Full Name *</label>
            <input type="text" name="name" class="form-control" placeholder="Official full name" required />
          </div>
          <div class="form-group">
            <label class="form-label">Mobile Number *</label>
            <input type="tel" name="phone" class="form-control" placeholder="Official mobile" required />
          </div>
        </div>

        <div class="form-group">
          <label class="form-label">Official Email *</label>
          <input type="email" name="email" class="form-control" placeholder="name@dept.gov.in" required />
        </div>

        <div class="form-group">
          <label class="form-label">Government Employee ID *</label>
          <input type="text" name="employeeId" class="form-control" placeholder="e.g. GOV-PB-2024-0012" required />
        </div>

        <div class="form-section-title" style="margin-top:1.25rem;">Department & Role</div>

        <div class="form-group">
          <label class="form-label">Department *</label>
          <select name="department" class="form-control" required>
            <option value="">Select your department</option>
            <% departments.forEach(d => { %>
              <option value="<%= d._id %>"><%= d.name %> (<%= d.code %>)</option>
            <% }) %>
          </select>
          <% if (departments.length === 0) { %>
            <small style="color:var(--warning);font-size:0.75rem;">No departments configured yet. Contact admin.</small>
          <% } %>
        </div>

        <div class="form-group">
          <label class="form-label">Designation *</label>
          <select name="designation" class="form-control" required>
            <option value="">Select designation</option>
            <option>District Collector</option>
            <option>Sub-Divisional Magistrate (SDM)</option>
            <option>Block Development Officer</option>
            <option>Municipal Commissioner</option>
            <option>Executive Engineer</option>
            <option>Chief Medical Officer</option>
            <option>Superintendent of Police</option>
            <option>Revenue Officer</option>
            <option>Agriculture Officer</option>
            <option>Sanitation Inspector</option>
            <option>Electricity Inspector</option>
            <option>Other Government Officer</option>
          </select>
        </div>

        <div class="form-section-title" style="margin-top:1.25rem;">Jurisdiction</div>

        <div class="form-grid-2">
          <div class="form-group">
            <label class="form-label">State *</label>
            <select name="state" class="form-control" required>
              <option value="">Select State</option>
              <option>Andhra Pradesh</option><option>Arunachal Pradesh</option><option>Assam</option>
              <option>Bihar</option><option>Chhattisgarh</option><option>Goa</option>
              <option>Gujarat</option><option>Haryana</option><option>Himachal Pradesh</option>
              <option>Jharkhand</option><option>Karnataka</option><option>Kerala</option>
              <option>Madhya Pradesh</option><option>Maharashtra</option><option>Manipur</option>
              <option>Meghalaya</option><option>Mizoram</option><option>Nagaland</option>
              <option>Odisha</option><option>Punjab</option><option>Rajasthan</option>
              <option>Tamil Nadu</option><option>Telangana</option><option>Uttar Pradesh</option>
              <option>Uttarakhand</option><option>West Bengal</option><option>Delhi</option>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label">District *</label>
            <input type="text" name="district" class="form-control" placeholder="Your district" required />
          </div>
        </div>

        <div class="form-section-title" style="margin-top:1.25rem;">Account Security</div>

        <div class="form-grid-2">
          <div class="form-group">
            <label class="form-label">Password *</label>
            <input type="password" name="password" class="form-control" placeholder="Min. 6 characters" minlength="6" required />
          </div>
          <div class="form-group">
            <label class="form-label">Confirm Password *</label>
            <input type="password" name="confirmPassword" class="form-control" placeholder="Re-enter password" required />
          </div>
        </div>

        <div style="font-size:0.75rem;color:var(--gray-600);margin-bottom:1.25rem;padding:0.75rem;background:var(--warning-light);border-radius:var(--radius-sm);border-left:3px solid var(--warning);">
          <i class="fas fa-exclamation-triangle" style="color:var(--warning);margin-right:0.3rem;"></i>
          False registration with fake government credentials is a punishable offence under IT Act 2000.
        </div>

        <button type="submit" class="btn btn-primary btn-block btn-lg">
          <i class="fas fa-paper-plane"></i> Submit Registration for Approval
        </button>
      </form>

      <p style="text-align:center;margin-top:1.25rem;font-size:0.85rem;color:var(--gray-600);">
        Already registered? <a href="/login?role=adhikari" style="color:var(--saffron);font-weight:600;text-decoration:none;">Login here</a>
      </p>
    </div>
  </div>
</body>
</html>
