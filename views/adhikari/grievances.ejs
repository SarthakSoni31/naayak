<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=Noto+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  <link rel="stylesheet" href="/css/naayak.css" />
</head>
<body>
<div class="layout">
  <%- include('../partials/adhikari-sidebar') %>
  <div class="main-content">
    <div class="topbar">
      <div class="topbar-left"><span class="page-title">Grievances</span></div>
    </div>
    <div class="content">

      <!-- View toggle + filters -->
      <div class="filters-bar">
        <div style="display:flex;gap:0.4rem;margin-right:0.5rem;">
          <a href="?view=mine<%= filters.status ? '&status='+filters.status : '' %>" class="btn btn-sm <%= filters.view==='mine' ? 'btn-primary' : 'btn-outline' %>">My Assignments</a>
          <a href="?view=dept<%= filters.status ? '&status='+filters.status : '' %>" class="btn btn-sm <%= filters.view==='dept' ? 'btn-primary' : 'btn-outline' %>">Dept Queue</a>
        </div>
        <i class="fas fa-filter" style="color:var(--gray-400);"></i>
        <form method="GET" style="display:flex;gap:0.5rem;">
          <input type="hidden" name="view" value="<%= filters.view || 'mine' %>" />
          <select name="status" class="filter-select" onchange="this.form.submit()">
            <option value="">All Statuses</option>
            <% ['PENDING','ASSIGNED','IN_PROGRESS','RESOLVED','REJECTED'].forEach(s => { %>
              <option value="<%= s %>" <%= filters.status===s?'selected':'' %>><%= s.replace('_',' ') %></option>
            <% }) %>
          </select>
          <select name="urgency" class="filter-select" onchange="this.form.submit()">
            <option value="">All Urgencies</option>
            <% ['HIGH','MEDIUM','LOW'].forEach(u => { %>
              <option value="<%= u %>" <%= filters.urgency===u?'selected':'' %>><%= u %></option>
            <% }) %>
          </select>
        </form>
      </div>

      <div class="card">
        <div class="card-header">
          <h3 class="card-title">Grievances (<%= grievances.length %>)</h3>
        </div>
        <div class="table-wrapper">
          <table>
            <thead><tr><th>ID</th><th>Citizen</th><th>Title</th><th>Category</th><th>Urgency</th><th>Status</th><th>Date</th><th>Action</th></tr></thead>
            <tbody>
              <% if (grievances.length === 0) { %>
                <tr><td colspan="8"><div class="empty-state"><div class="empty-icon">✅</div><h3>All clear!</h3><p>No grievances in this view</p></div></td></tr>
              <% } %>
              <% grievances.forEach(g => { %>
                <tr>
                  <td><a href="/adhikari/grievances/<%= g._id %>" style="font-family:'Rajdhani',sans-serif;font-weight:700;color:var(--navy);text-decoration:none;font-size:0.88rem;"><%= g.grievanceId %></a></td>
                  <td><div style="font-weight:600;font-size:0.83rem;"><%= g.citizen?.name %></div><div style="font-size:0.72rem;color:var(--gray-400);"><%= g.citizen?.district %></div></td>
                  <td style="max-width:160px;font-size:0.83rem;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="<%= g.title %>"><%= g.title %></td>
                  <td><span class="badge badge-primary" style="font-size:0.68rem;"><%= g.category %></span></td>
                  <td><span class="badge badge-<%= g.urgency.toLowerCase() %>"><span class="urgency-dot <%= g.urgency %>"></span><%= g.urgency %></span></td>
                  <td>
                    <% const sm={PENDING:'pending',ASSIGNED:'assigned',IN_PROGRESS:'progress',RESOLVED:'resolved',REJECTED:'rejected'}; %>
                    <span class="badge badge-<%= sm[g.status] %>"><%= g.status.replace('_',' ') %></span>
                  </td>
                  <td style="font-size:0.75rem;color:var(--gray-600);"><%= new Date(g.createdAt).toLocaleDateString('en-IN') %></td>
                  <td><a href="/adhikari/grievances/<%= g._id %>" class="btn btn-outline btn-sm btn-icon"><i class="fas fa-eye"></i></a></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>
</body>
</html>
