<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=Noto+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  <link rel="stylesheet" href="/css/naayak.css" />
</head>
<body>
<div class="layout">
  <%- include('../partials/adhikari-sidebar') %>
  <div class="main-content">
    <div class="topbar">
      <div class="topbar-left"><span class="page-title">Officer Dashboard</span></div>
      <div class="topbar-right">
        <span style="font-size:0.78rem;color:var(--gray-600);"><%= new Date().toLocaleDateString('en-IN',{weekday:'long',day:'numeric',month:'long'}) %></span>
      </div>
    </div>
    <div class="content">

      <!-- Welcome -->
      <div style="background:linear-gradient(135deg,var(--navy) 0%,var(--navy-light) 100%);border-radius:var(--radius);padding:1.5rem 2rem;margin-bottom:1.75rem;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;">
        <div>
          <h2 style="color:var(--white);margin-bottom:0.25rem;">Namaste, <%= user.name %> 🙏</h2>
          <p style="color:rgba(255,255,255,0.6);font-size:0.85rem;">
            <%= user.designation %> · <%= user.department?.name || 'Department' %> · <%= user.district %>, <%= user.state %>
          </p>
        </div>
        <a href="/adhikari/grievances?view=mine&status=ASSIGNED" class="btn btn-saffron btn-sm">
          <i class="fas fa-inbox"></i> Assigned (<%= stats.assigned %>)
        </a>
      </div>

      <div class="stats-grid">
        <div class="stat-card saffron">
          <div class="stat-icon"><i class="fas fa-inbox"></i></div>
          <div class="stat-info"><div class="stat-value"><%= stats.assigned %></div><div class="stat-label">Assigned to Me</div></div>
        </div>
        <div class="stat-card primary">
          <div class="stat-icon"><i class="fas fa-spinner"></i></div>
          <div class="stat-info"><div class="stat-value"><%= stats.inProgress %></div><div class="stat-label">In Progress</div></div>
        </div>
        <div class="stat-card success">
          <div class="stat-icon"><i class="fas fa-check-circle"></i></div>
          <div class="stat-info"><div class="stat-value"><%= stats.resolved %></div><div class="stat-label">Resolved</div></div>
        </div>
        <div class="stat-card danger">
          <div class="stat-icon"><i class="fas fa-exclamation-circle"></i></div>
          <div class="stat-info"><div class="stat-value"><%= stats.highUrgency %></div><div class="stat-label">High Urgency</div></div>
        </div>
      </div>

      <div class="card">
        <div class="card-header">
          <h3 class="card-title"><i class="fas fa-list" style="color:var(--saffron);margin-right:0.5rem;"></i>Recent Grievances</h3>
          <a href="/adhikari/grievances" class="btn btn-outline btn-sm">View All</a>
        </div>
        <div class="table-wrapper">
          <table>
            <thead><tr><th>ID</th><th>Citizen</th><th>Title</th><th>Urgency</th><th>Status</th><th>Date</th><th>Action</th></tr></thead>
            <tbody>
              <% if (recentGrievances.length === 0) { %>
                <tr><td colspan="7"><div class="empty-state" style="padding:2rem;"><div class="empty-icon">📂</div><h3>No grievances assigned yet</h3></div></td></tr>
              <% } %>
              <% recentGrievances.forEach(g => { %>
                <tr>
                  <td><span style="font-family:'Rajdhani',sans-serif;font-weight:700;color:var(--navy);font-size:0.85rem;"><%= g.grievanceId %></span></td>
                  <td><div style="font-weight:600;font-size:0.83rem;"><%= g.citizen?.name %></div><div style="font-size:0.72rem;color:var(--gray-400);"><%= g.citizen?.district %></div></td>
                  <td style="max-width:160px;font-size:0.83rem;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= g.title %></td>
                  <td><span class="badge badge-<%= g.urgency.toLowerCase() %>"><span class="urgency-dot <%= g.urgency %>"></span><%= g.urgency %></span></td>
                  <td>
                    <% const sm={PENDING:'pending',ASSIGNED:'assigned',IN_PROGRESS:'progress',RESOLVED:'resolved',REJECTED:'rejected'}; %>
                    <span class="badge badge-<%= sm[g.status] %>"><%= g.status.replace('_',' ') %></span>
                  </td>
                  <td style="font-size:0.75rem;color:var(--gray-600);"><%= new Date(g.createdAt).toLocaleDateString('en-IN') %></td>
                  <td><a href="/adhikari/grievances/<%= g._id %>" class="btn btn-outline btn-sm btn-icon"><i class="fas fa-eye"></i></a></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>
</body>
</html>
