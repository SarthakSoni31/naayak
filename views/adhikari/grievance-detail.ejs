<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=Noto+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  <link rel="stylesheet" href="/css/naayak.css" />
</head>
<body>
<div class="layout">
  <%- include('../partials/adhikari-sidebar') %>
  <div class="main-content">
    <div class="topbar">
      <div class="topbar-left">
        <a href="/adhikari/grievances" style="color:var(--gray-600);text-decoration:none;font-size:0.85rem;display:flex;align-items:center;gap:0.3rem;"><i class="fas fa-arrow-left"></i> Back</a>
        <span style="color:var(--gray-300);margin:0 0.5rem;">|</span>
        <span class="page-title"><%= grievance.grievanceId %></span>
      </div>
    </div>
    <div class="content">
      <div style="display:grid;grid-template-columns:1fr 320px;gap:1.5rem;align-items:start;">

        <!-- Details -->
        <div style="display:flex;flex-direction:column;gap:1.25rem;">
          <div class="card">
            <div class="card-body">
              <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:1rem;flex-wrap:wrap;margin-bottom:1.25rem;">
                <div>
                  <h2 style="font-size:1.35rem;margin-bottom:0.5rem;"><%= grievance.title %></h2>
                  <div style="display:flex;gap:0.5rem;flex-wrap:wrap;align-items:center;">
                    <% const sm={PENDING:'pending',ASSIGNED:'assigned',IN_PROGRESS:'progress',RESOLVED:'resolved',REJECTED:'rejected'}; %>
                    <span class="badge badge-<%= sm[grievance.status] %>"><%= grievance.status.replace('_',' ') %></span>
                    <span class="badge badge-<%= grievance.urgency.toLowerCase() %>"><span class="urgency-dot <%= grievance.urgency %>"></span><%= grievance.urgency %></span>
                    <span class="badge badge-primary"><%= grievance.category %></span>
                    <% if (grievance.aiConfidence > 0) { %>
                      <span class="ai-chip"><i class="fas fa-robot"></i> AI: <%= grievance.aiConfidence %>%</span>
                    <% } %>
                  </div>
                </div>
                <div style="text-align:right;font-size:0.78rem;color:var(--gray-600);">
                  Filed <%= new Date(grievance.createdAt).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'}) %>
                </div>
              </div>

              <div class="form-section-title">Description</div>
              <p style="font-size:0.88rem;line-height:1.7;color:var(--gray-800);background:var(--off-white);padding:1rem;border-radius:var(--radius-sm);border-left:3px solid var(--saffron);">
                <%= grievance.description %>
              </p>

              <div class="grievance-meta" style="margin-top:1.25rem;">
                <div class="meta-item"><div class="meta-label">Citizen</div><div class="meta-value"><%= grievance.citizen?.name %></div></div>
                <div class="meta-item"><div class="meta-label">Phone</div><div class="meta-value"><%= grievance.citizen?.phone %></div></div>
                <div class="meta-item"><div class="meta-label">District</div><div class="meta-value"><%= grievance.citizen?.district %></div></div>
                <div class="meta-item"><div class="meta-label">State</div><div class="meta-value"><%= grievance.citizen?.state %></div></div>
                <div class="meta-item"><div class="meta-label">Location</div><div class="meta-value"><%= grievance.location || '—' %></div></div>
                <div class="meta-item"><div class="meta-label">Address</div><div class="meta-value"><%= grievance.citizen?.address || '—' %></div></div>
              </div>

              <% if (grievance.resolutionNote) { %>
                <div style="margin-top:1rem;padding:0.85rem;background:var(--success-light);border-radius:var(--radius-sm);border-left:3px solid var(--success);">
                  <div style="font-size:0.72rem;font-weight:700;color:var(--success);text-transform:uppercase;letter-spacing:0.06em;margin-bottom:0.25rem;">Resolution Note</div>
                  <p style="font-size:0.85rem;color:var(--text);"><%= grievance.resolutionNote %></p>
                </div>
              <% } %>
            </div>
          </div>

          <!-- Timeline -->
          <div class="card">
            <div class="card-header"><h3 class="card-title"><i class="fas fa-history" style="color:var(--saffron);margin-right:0.5rem;"></i>Timeline</h3></div>
            <div class="card-body">
              <% if (!grievance.timeline?.length) { %>
                <p style="color:var(--gray-400);font-size:0.85rem;">No activity yet.</p>
              <% } else { %>
                <div class="timeline">
                  <% [...grievance.timeline].reverse().forEach(t => { %>
                    <div class="timeline-item">
                      <div class="timeline-time"><%= new Date(t.timestamp).toLocaleString('en-IN') %> · <strong><%= t.updatedBy %></strong></div>
                      <div class="timeline-status"><%= t.status?.replace('_',' ') %></div>
                      <div class="timeline-content"><%= t.message %></div>
                    </div>
                  <% }) %>
                </div>
              <% } %>
            </div>
          </div>
        </div>

        <!-- Action Panel -->
        <div style="position:sticky;top:80px;">
          <div class="card">
            <div class="card-header" style="background:var(--navy);">
              <h3 class="card-title" style="color:var(--white);"><i class="fas fa-edit" style="color:var(--saffron);margin-right:0.5rem;"></i>Update Status</h3>
            </div>
            <div class="card-body">
              <form action="/adhikari/grievances/<%= grievance._id %>/update" method="POST">
                <div class="form-group">
                  <label class="form-label">New Status *</label>
                  <select name="status" class="form-control" required>
                    <% ['ASSIGNED','IN_PROGRESS','RESOLVED','REJECTED'].forEach(s => { %>
                      <option value="<%= s %>" <%= grievance.status===s?'selected':'' %>><%= s.replace('_',' ') %></option>
                    <% }) %>
                  </select>
                </div>
                <div class="form-group">
                  <label class="form-label">Update Note *</label>
                  <textarea name="message" class="form-control" rows="3" placeholder="Describe action taken, investigation findings, or reason for status change..." required></textarea>
                </div>
                <div class="form-group" id="resolutionBlock" style="display:none;">
                  <label class="form-label">Resolution Note</label>
                  <textarea name="resolutionNote" class="form-control" rows="3" placeholder="Describe how the issue was resolved..."></textarea>
                </div>
                <button type="submit" class="btn btn-saffron btn-block">
                  <i class="fas fa-save"></i> Update Grievance
                </button>
              </form>
            </div>
          </div>

          <div style="margin-top:1rem;padding:1rem;background:var(--saffron-pale);border-radius:var(--radius);border:1px solid rgba(255,153,51,0.3);">
            <p style="font-size:0.78rem;color:var(--gray-800);font-weight:600;margin-bottom:0.5rem;"><i class="fas fa-lightbulb" style="color:var(--saffron);"></i> Officer Guidelines</p>
            <ul style="font-size:0.75rem;color:var(--gray-600);list-style:none;display:flex;flex-direction:column;gap:0.3rem;">
              <li>• Set to <strong>IN_PROGRESS</strong> when you start working</li>
              <li>• Always add a detailed update note</li>
              <li>• Resolve only when fully addressed</li>
              <li>• High urgency cases need same-day response</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
<script>
  document.querySelector('[name=status]').addEventListener('change', function() {
    document.getElementById('resolutionBlock').style.display = this.value === 'RESOLVED' ? 'block' : 'none';
  });
</script>
</body>
</html>
