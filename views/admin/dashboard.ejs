<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=Noto+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  <link rel="stylesheet" href="/css/naayak.css" />
</head>
<body>
<div class="layout">
  <%- include('../partials/admin-sidebar') %>

  <div class="main-content">
    <!-- Topbar -->
    <div class="topbar">
      <div class="topbar-left">
        <span class="page-title">Dashboard</span>
      </div>
      <div class="topbar-right">
        <span style="font-size:0.78rem;color:var(--gray-600);">
          <i class="fas fa-calendar-alt" style="margin-right:0.3rem;"></i>
          <%= new Date().toLocaleDateString('en-IN', {weekday:'long', year:'numeric', month:'long', day:'numeric'}) %>
        </span>
        <a href="/admin/grievances?status=PENDING" class="topbar-btn" title="Pending grievances">
          <i class="fas fa-bell"></i>
        </a>
      </div>
    </div>

    <div class="content">

      <!-- Welcome Banner -->
      <div style="background:linear-gradient(135deg, var(--navy) 0%, var(--navy-light) 100%);border-radius:var(--radius);padding:1.5rem 2rem;margin-bottom:1.75rem;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;">
        <div>
          <h2 style="color:var(--white);margin-bottom:0.25rem;font-size:1.4rem;">Namaste, <%= user.name %> 🙏</h2>
          <p style="color:rgba(255,255,255,0.65);font-size:0.85rem;">Naayak Admin Control Panel · <%= new Date().toLocaleDateString('en-IN') %></p>
        </div>
        <div style="display:flex;gap:0.75rem;flex-wrap:wrap;">
          <a href="/admin/grievances?status=PENDING" class="btn btn-saffron btn-sm">
            <i class="fas fa-inbox"></i> Pending (<%= stats.pendingGrievances %>)
          </a>
          <a href="/admin/adhikaris?approved=false" class="btn btn-outline btn-sm" style="color:var(--white);border-color:rgba(255,255,255,0.3);">
            <i class="fas fa-user-clock"></i> Approvals (<%= stats.pendingAdhikari %>)
          </a>
        </div>
      </div>

      <!-- Stats Grid -->
      <div class="stats-grid">
        <div class="stat-card primary">
          <div class="stat-icon"><i class="fas fa-file-alt"></i></div>
          <div class="stat-info">
            <div class="stat-value"><%= stats.totalGrievances %></div>
            <div class="stat-label">Total Grievances</div>
          </div>
        </div>
        <div class="stat-card warning">
          <div class="stat-icon"><i class="fas fa-clock"></i></div>
          <div class="stat-info">
            <div class="stat-value"><%= stats.pendingGrievances %></div>
            <div class="stat-label">Pending Assignment</div>
          </div>
        </div>
        <div class="stat-card success">
          <div class="stat-icon"><i class="fas fa-check-circle"></i></div>
          <div class="stat-info">
            <div class="stat-value"><%= stats.resolvedGrievances %></div>
            <div class="stat-label">Resolved</div>
          </div>
        </div>
        <div class="stat-card danger">
          <div class="stat-icon"><i class="fas fa-exclamation-circle"></i></div>
          <div class="stat-info">
            <div class="stat-value"><%= stats.highUrgency %></div>
            <div class="stat-label">High Urgency Active</div>
          </div>
        </div>
        <div class="stat-card saffron">
          <div class="stat-icon"><i class="fas fa-users"></i></div>
          <div class="stat-info">
            <div class="stat-value"><%= stats.totalCitizens %></div>
            <div class="stat-label">Registered Citizens</div>
          </div>
        </div>
        <div class="stat-card info">
          <div class="stat-icon"><i class="fas fa-id-badge"></i></div>
          <div class="stat-info">
            <div class="stat-value"><%= stats.totalAdhikari %></div>
            <div class="stat-label">Active Officers</div>
          </div>
        </div>
      </div>

      <!-- Charts + Recent Grievances -->
      <div class="grid-2" style="margin-bottom:1.5rem;">

        <!-- Category Breakdown -->
        <div class="card">
          <div class="card-header">
            <h3 class="card-title"><i class="fas fa-chart-pie" style="color:var(--saffron);margin-right:0.5rem;"></i>Grievances by Category</h3>
          </div>
          <div class="card-body">
            <canvas id="categoryChart" height="200"></canvas>
          </div>
        </div>

        <!-- Urgency Breakdown -->
        <div class="card">
          <div class="card-header">
            <h3 class="card-title"><i class="fas fa-tachometer-alt" style="color:var(--saffron);margin-right:0.5rem;"></i>Urgency Distribution</h3>
          </div>
          <div class="card-body" style="display:flex;flex-direction:column;gap:1rem;">
            <% const urgencyData = {}; deptStats.forEach(d => urgencyData[d._id] = d.count); %>
            <% const total = stats.totalGrievances || 1; %>

            <% [['HIGH','danger','🔴'], ['MEDIUM','warning','🟡'], ['LOW','success','🟢']].forEach(([u, cls, emoji]) => { %>
              <% // We'll just show relative bars based on status distribution %>
            <% }) %>

            <!-- Urgency bars as static display using deptStats -->
            <div style="display:flex;flex-direction:column;gap:0.85rem;">
              <% deptStats.slice(0,6).forEach(cat => { %>
                <div>
                  <div style="display:flex;justify-content:space-between;margin-bottom:0.3rem;font-size:0.8rem;">
                    <span style="font-weight:600;color:var(--text);"><%= cat._id %></span>
                    <span style="color:var(--gray-600);"><%= cat.count %> cases</span>
                  </div>
                  <div style="height:8px;background:var(--gray-100);border-radius:4px;overflow:hidden;">
                    <div style="height:100%;width:<%= Math.round((cat.count/total)*100) %>%;background:linear-gradient(90deg,var(--saffron),var(--navy));border-radius:4px;transition:width 1s ease;"></div>
                  </div>
                </div>
              <% }) %>
              <% if (deptStats.length === 0) { %>
                <div class="empty-state" style="padding:2rem;">
                  <div class="empty-icon">📊</div>
                  <p>No data yet</p>
                </div>
              <% } %>
            </div>
          </div>
        </div>
      </div>

      <!-- Recent Grievances Table -->
      <div class="card">
        <div class="card-header">
          <h3 class="card-title"><i class="fas fa-list" style="color:var(--saffron);margin-right:0.5rem;"></i>Recent Grievances</h3>
          <a href="/admin/grievances" class="btn btn-outline btn-sm">View All</a>
        </div>
        <div class="table-wrapper">
          <table>
            <thead>
              <tr>
                <th>Grievance ID</th>
                <th>Citizen</th>
                <th>Category</th>
                <th>Urgency</th>
                <th>Status</th>
                <th>Department</th>
                <th>Filed On</th>
                <th>Action</th>
              </tr>
            </thead>
            <tbody>
              <% if (recentGrievances.length === 0) { %>
                <tr><td colspan="8" style="text-align:center;padding:3rem;color:var(--gray-400);">No grievances filed yet</td></tr>
              <% } %>
              <% recentGrievances.forEach(g => { %>
                <tr>
                  <td><span style="font-family:'Rajdhani',sans-serif;font-weight:700;color:var(--navy);font-size:0.88rem;"><%= g.grievanceId %></span></td>
                  <td>
                    <div style="font-weight:600;font-size:0.85rem;"><%= g.citizen?.name || 'N/A' %></div>
                    <div style="font-size:0.72rem;color:var(--gray-600);"><%= g.citizen?.district || '' %></div>
                  </td>
                  <td><span class="badge badge-primary"><%= g.category %></span></td>
                  <td>
                    <span class="badge badge-<%= g.urgency.toLowerCase() %>">
                      <span class="urgency-dot <%= g.urgency %>"></span><%= g.urgency %>
                    </span>
                  </td>
                  <td>
                    <% const statusMap = { PENDING:'pending', ASSIGNED:'assigned', IN_PROGRESS:'progress', RESOLVED:'resolved', REJECTED:'rejected', ESCALATED:'escalated' }; %>
                    <span class="badge badge-<%= statusMap[g.status] || 'pending' %>"><%= g.status.replace('_',' ') %></span>
                  </td>
                  <td style="font-size:0.82rem;color:var(--gray-600);"><%= g.department?.name || '— Unassigned' %></td>
                  <td style="font-size:0.78rem;color:var(--gray-600);">
                    <%= new Date(g.createdAt).toLocaleDateString('en-IN') %>
                  </td>
                  <td>
                    <a href="/admin/grievances/<%= g._id %>" class="btn btn-outline btn-sm btn-icon" title="View">
                      <i class="fas fa-eye"></i>
                    </a>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Pending Approvals Banner -->
      <% if (stats.pendingAdhikari > 0) { %>
      <div style="margin-top:1.5rem;background:var(--warning-light);border:1px solid var(--warning);border-radius:var(--radius);padding:1rem 1.5rem;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;">
        <div style="display:flex;align-items:center;gap:0.75rem;">
          <i class="fas fa-user-clock" style="color:var(--warning);font-size:1.3rem;"></i>
          <div>
            <strong style="color:var(--warning);">Pending Officer Approvals</strong>
            <p style="font-size:0.82rem;color:var(--gray-600);margin:0;"><%= stats.pendingAdhikari %> officer registration(s) awaiting your review</p>
          </div>
        </div>
        <a href="/admin/adhikaris?approved=false" class="btn btn-saffron btn-sm">
          Review Now <i class="fas fa-arrow-right"></i>
        </a>
      </div>
      <% } %>

    </div>
  </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js"></script>
<script>
  const deptStats = <%- JSON.stringify(deptStats) %>;

  if (deptStats.length > 0) {
    const ctx = document.getElementById('categoryChart').getContext('2d');
    new Chart(ctx, {
      type: 'doughnut',
      data: {
        labels: deptStats.map(d => d._id),
        datasets: [{
          data: deptStats.map(d => d.count),
          backgroundColor: ['#0D1B3E','#FF9933','#138808','#0277BD','#D32F2F','#7B1FA2','#F57C00','#00796B','#5D4037'],
          borderWidth: 2,
          borderColor: '#fff'
        }]
      },
      options: {
        responsive: true,
        plugins: {
          legend: { position: 'bottom', labels: { font: { family: 'Noto Sans', size: 11 }, padding: 12 } }
        }
      }
    });
  }
</script>
</body>
</html>
